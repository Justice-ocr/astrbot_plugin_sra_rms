{
  "sra_host": {
    "description": "SRA Server 地址",
    "type": "string",
    "hint": "SRA前端Server的地址，默认 localhost",
    "default": "localhost"
  },
  "sra_port": {
    "description": "SRA Server 端口",
    "type": "int",
    "hint": "SRA前端Server的端口，默认 5073",
    "default": 5073
  },
  "sra_executable_path": {
    "description": "SRA 可执行文件路径",
    "type": "string",
    "hint": "用于 /sra start-server 启动本机 SRA。只允许填写已安装的 .exe 路径；留空则不启用启动功能。",
    "default": ""
  },
  "sra_working_directory": {
    "description": "SRA 工作目录",
    "type": "string",
    "hint": "启动 SRA 时使用的工作目录。留空时默认使用可执行文件所在目录。",
    "default": ""
  },
  "start_timeout": {
    "description": "启动等待秒数",
    "type": "int",
    "hint": "启动 SRA 后等待 HTTP Server 可连接的最长秒数，范围 0-60。",
    "default": 8
  },
  "auto_start_server": {
    "description": "插件初始化时自动启动 SRA",
    "type": "bool",
    "hint": "开启后插件初始化时会尝试启动配置好的本机 SRA 可执行文件。",
    "default": false
  },
  "enable_whitelist": {
    "description": "启用指令白名单",
    "type": "bool",
    "hint": "开启后仅白名单中的用户可使用 /sra 指令",
    "default": false
  },
  "whitelist_users": {
    "description": "指令白名单",
    "type": "template_list",
    "hint": "添加允许使用 /sra 指令的用户。为空且启用白名单时所有人不可用。",
    "templates": {
      "entry": {
        "name": "白名单条目",
        "display_item": "account_id",
        "items": {
          "platform": {
            "description": "消息平台",
            "type": "string",
            "default": "all",
            "options": [
              "all",
              "aiocqhttp",
              "qq_official",
              "qq_official_webhook",
              "telegram",
              "wecom",
              "lark",
              "dingtalk",
              "discord",
              "slack",
              "kook",
              "webchat"
            ],
            "labels": [
              "全部",
              "QQ (OneBot v11)",
              "QQ 官方",
              "QQ 官方 Webhook",
              "Telegram",
              "企业微信",
              "飞书",
              "钉钉",
              "Discord",
              "Slack",
              "KOOK",
              "WebChat"
            ]
          },
          "msg_type": {
            "description": "消息类型",
            "type": "string",
            "default": "all",
            "options": ["all", "group", "private"],
            "labels": ["全部", "群聊", "私聊"]
          },
          "account_id": {
            "description": "账号/群号",
            "type": "string",
            "default": "",
            "hint": "填写/sid指令输出的UMO末尾账号(如3786293235)或群号"
          }
        }
      }
    }
  }
}
